# Compose settings
OVERLEAF_IMAGE=lumia-overleaf:latest
OVERLEAF_BASE_TAG=lumia-overleaf-base:latest
OVERLEAF_PHUSION_BASEIMAGE_TAG=phusion/baseimage:noble-1.0.2
OVERLEAF_FORCE_BASE_REBUILD=false
OVERLEAF_TEXLIVE_SCHEME=scheme-medium
OVERLEAF_HTTP_BIND_IP=127.0.0.1
OVERLEAF_HTTP_PORT=38080
OVERLEAF_CONTAINER_NAME=lumia-overleaf
OVERLEAF_MONGO_CONTAINER_NAME=lumia-overleaf-mongo
OVERLEAF_REDIS_CONTAINER_NAME=lumia-overleaf-redis
OVERLEAF_MONGO_IMAGE=mongo:8.0
OVERLEAF_TEXLIVE_EXTRA_PACKAGES="collection-langcjk microtype tools caption booktabs multirow cleveref mathtools todonotes xcolor hyperref enumitem algorithms algorithmicx natbib url xurl units wrapfig float sttools adjustbox threeparttable tablefootnote soul ulem listings pgf pgfplots siunitx makecell preprint forloop xifthen ifmtarg cmap psnfss textcase changepage datetime fmtcount fancyhdr lastpage titlesec needspace kvoptions tcolorbox fontawesome5 xcharter fontaxes mweights newtx zlmtt extsizes geometry colortbl forest elocalloc changes xstring truncate bclogo mdframed zref lipsum tocloft bbding epigraph nextpage minitoc textgreek cjk greek-fontenc cbfonts cbfonts-fd"

# Core Overleaf settings
OVERLEAF_APP_NAME=LUMIA Overleaf
OVERLEAF_NAV_TITLE=LUMIA Overleaf
OVERLEAF_SITE_URL=https://overleaf.example.com
OVERLEAF_ADMIN_EMAIL=admin@example.com
OVERLEAF_SITE_LANGUAGE=zh-CN
OVERLEAF_SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
WEB_API_USER=overleaf
WEB_API_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD

# Email delivery
# Copy the SMTP host/port/auth/TLS values from /etc/slurm-mail/slurm-mail.conf on the Lumia server.
# That file is root-owned on Lumia, so you need sudo/root access to read it.
# Keep the display name as "LUMIA Overleaf" so activation and reset emails are branded clearly.
OVERLEAF_EMAIL_FROM_ADDRESS="LUMIA Overleaf <noreply@example.com>"
# OVERLEAF_EMAIL_REPLY_TO=support@example.com
# OVERLEAF_EMAIL_SMTP_HOST=127.0.0.1
# OVERLEAF_EMAIL_SMTP_PORT=25
# OVERLEAF_EMAIL_SMTP_SECURE=false
# OVERLEAF_EMAIL_SMTP_IGNORE_TLS=true
# OVERLEAF_EMAIL_SMTP_USER=
# OVERLEAF_EMAIL_SMTP_PASS=
# OVERLEAF_EMAIL_SMTP_TLS_REJECT_UNAUTH=false
# OVERLEAF_EMAIL_SMTP_NAME=localhost
# OVERLEAF_EMAIL_SMTP_LOGGER=false

# Internal services
OVERLEAF_MONGO_URL=mongodb://mongo/sharelatex
OVERLEAF_REDIS_HOST=redis
REDIS_HOST=redis

# Recommended CE runtime options
ENABLED_LINKED_FILE_TYPES=project_file,project_output_file
ENABLE_CONVERSIONS=true
EMAIL_CONFIRMATION_DISABLED=true

# LDAP authentication
EXTERNAL_AUTH=ldap
OVERLEAF_LDAP_URL=ldap://192.168.102.101:389
OVERLEAF_LDAP_SEARCH_BASE=ou=People,dc=sugon,dc=com
# Assumption: cluster users authenticate with uid.
OVERLEAF_LDAP_SEARCH_FILTER=(uid={{username}})
OVERLEAF_LDAP_BIND_DN=cn=admin,dc=sugon,dc=com
OVERLEAF_LDAP_BIND_CREDENTIALS=REPLACE_WITH_LDAP_BIND_PASSWORD
OVERLEAF_LDAP_EMAIL_ATT=mail
OVERLEAF_LDAP_NAME_ATT=cn
OVERLEAF_LDAP_LAST_NAME_ATT=sn
OVERLEAF_LDAP_UID_ATT=uid
OVERLEAF_LDAP_OVERLEAF_EMAIL_DOMAIN=lumia.cn
OVERLEAF_LDAP_UPDATE_USER_DETAILS_ON_LOGIN=true
OVERLEAF_LDAP_LOGIN_LABEL=LUMIA LDAP
# Keep loopback in the list because the internal nginx inside the container must stay trusted.
# Add your external reverse proxy IP/subnet only if it is not on the same host loopback path.
# OVERLEAF_TRUSTED_PROXY_IPS=loopback,172.18.0.0/16

# Enable review/comments UI in CE
OVERLEAF_ENABLE_COMMENTS=true

# Enable this when the site is behind HTTPS.
OVERLEAF_SECURE_COOKIE=true
